    <string notr="true">QTableWidget {
    background: rgba(10,20,40,0.6);
    color: #d6e0ff;
    border: 1px solid #1f2a44;
    border-radius: 10px;
    gridline-color: #2a3c63;
    font-size: 14px;
    selection-background-color: #324f9e;
    selection-color: white;
}

/* Header */
QHeaderView::section {
    background-color: #1f2a44;
    color: #c7d2ff;
    padding: 6px;
    border: none;
    font-weight: bold;
}

/* Alternating row colors */
QTableWidget::item {
    background-color: #111b31;
}

QTableWidget::item:alternate {
    background-color: #16223d;
}

/* Selected row */
QTableWidget::item:selected {
    background-color: #3f63c8;
    color: white;
}
