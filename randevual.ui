  <widget class="QDateEdit" name="dogum_date">
   <property name="geometry">
    <rect>
     <x>10</x>
     <y>290</y>
     <width>181</width>
     <height>41</height>
    </rect>
   </property>
   <property name="styleSheet">
    <string notr="true">QDateEdit {
    background-color: rgba(15, 23, 41, 0.7);
    border: 1px solid #2a3c63;
    border-radius: 8px;
    padding: 6px 10px;
    color: #d6e0ff;
    font-size: 14px;
}

QDateEdit:hover {
    border: 1px solid #3c5aa6;
}

QDateEdit:focus {
    border: 1px solid #5f8cff;
    background-color: rgba(20, 30, 60, 0.9);
}

/* Açılır ok butonu */
QDateEdit::drop-down {
    border: none;
    width: 22px;
    background-color: transparent;
}

/* Ok simgesi alanı */
QDateEdit::down-arrow {
    image: url(:/qt-project.org/styles/commonstyle/images/arrowdown.png);
    width: 12px;
    height: 12px;
}

/* Takvim popup */
QCalendarWidget {
    background-color: #0f1729;
    border: 1px solid #2a3c63;
    color: #e3e7ff;
}

/* Gün başlıkları */
QCalendarWidget QWidget {
    alternate-background-color: #13203b;
}

/* Günler */
QCalendarWidget QAbstractItemView:enabled {
    selection-background-color: #3f63c8;
    selection-color: white;
    background-color: #0f1729;
    color: #d6e0ff;
    outline: 0;
}

/* Hover efekti */
QCalendarWidget QAbstractItemView:item:hover {
    background-color: #243a70;
}

/* Bugün vurgusu */
QCalendarWidget QAbstractItemView:item:selected {
    background-color: #4f7fff;
    color: white;
}
</string>
   </property>
  </widget>
