   <property name="styleSheet">
    <string notr="true">QTimeEdit {
    background-color: rgba(15, 23, 41, 0.7);
    border: 1px solid #2a3c63;
    border-radius: 8px;
    padding: 6px 10px;
    color: #d6e0ff;
    font-size: 14px;
}

QTimeEdit:hover {
    border: 1px solid #3c5aa6;
}

QTimeEdit:focus {
    border: 1px solid #5f8cff;
    background-color: rgba(20, 30, 60, 0.9);
}

/* Ok butonları alanı */
QTimeEdit::up-button,
QTimeEdit::down-button {
    background: transparent;
    border: none;
    width: 18px;
}

/* Yukarı ok */
QTimeEdit::up-arrow {
    image: url(:/qt-project.org/styles/commonstyle/images/arrowup.png);
    width: 10px;
    height: 10px;
}

/* Aşağı ok */
QTimeEdit::down-arrow {
    image: url(:/qt-project.org/styles/commonstyle/images/arrowdown.png);
    width: 10px;
    height: 10px;
}

/* Seçili alan */
QTimeEdit::section {
    color: #e5ebff;
}
</string>
   </property>
