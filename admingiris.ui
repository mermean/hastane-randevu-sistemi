     <widget class="QPushButton" name="hastane_button">
      <property name="styleSheet">
       <string notr="true">QPushButton{
    background-color: #3F5BD8;        /* soft mavi */
    color: white;
    border-radius: 12px;
    padding: 10px 22px;
    font-size: 14px;
    border: 1px solid rgba(255,255,255,0.08);
    font-weight: 500;
}

QPushButton:hover{
    background-color: #4E6CFF;        /* hover = biraz parlak */
    border: 1px solid rgba(255,255,255,0.18);
}

QPushButton:pressed{
    background-color: #344AC0;        /* basılı = biraz koyu */
    border: 1px solid rgba(255,255,255,0.25);
}

QPushButton:disabled{
    background-color: #2E3A6C;
    color: #9AA4CC;
    border: 1px solid rgba(255,255,255,0.05);
}
</string>
      </property>
      <property name="text">
       <string>Hastane Ekle</string>
