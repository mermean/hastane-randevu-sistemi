   <property name="styleSheet">
    <string notr="true">QLineEdit {
    background: rgba(20, 30, 60, 0.6);
    color: #d6e0ff;
    border: 1px solid #2a3c63;
    border-radius: 10px;
    padding: 6px 10px;
    font-size: 14px;
}

/* Placeholder rengi */
QLineEdit[echoMode=&quot;0&quot;] {
    color: #9aa8d4;
}

/* Focus olduğunda */
QLineEdit:focus {
    border: 1px solid #4d79ff;
    background: rgba(30, 45, 90, 0.8);
}
</string>
   </property>
  </widget>
