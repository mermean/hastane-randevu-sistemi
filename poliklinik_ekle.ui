   <property name="styleSheet">
    <string notr="true">/* =========================
   COMBOBOX - MODERN STİL
   ========================= */

QComboBox {
    background: rgba(20, 30, 60, 0.6);
    color: #d6e0ff;
    border: 1px solid #2a3c63;
    border-radius: 8px;
    padding: 6px 10px;
    font-size: 14px;
}

/* Üzerine gelince */
QComboBox:hover {
    border: 1px solid #4d79ff;
}

/* Seçim yaparken (focus) */
QComboBox:focus {
    border: 1px solid #6d8cff;
    background: rgba(30, 45, 90, 0.7);
}

/* Aşağı ok butonu */
QComboBox::drop-down {
    border: none;
    width: 28px;
}

/* Ok simgesi alanı */
QComboBox::down-arrow {
    image: none;
    width: 0px;
    height: 0px;
    border-left: 6px solid #a8b9ff;
    border-top: 4px solid transparent;
    border-bottom: 4px solid transparent;
    margin-right: 8px;
}

/* Açılır liste */
QComboBox QAbstractItemView {
    background-color: #0f1729;
    color: #d6e0ff;
    border: 1px solid #2a3c63;
    selection-background-color: #324f9e;
    selection-color: white;
    outline: 0;
}

</string>
   </property>
  </widget>
  <widget class="QLineEdit" name="klinik_line">
   <property name="geometry">
